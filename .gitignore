# ========================
# SECURENET .gitignore
# ========================

# ---------- Entorno ----------
.env
.env.*
!.env.example

# ---------- Dependencias ----------
node_modules/

# ---------- Build ----------
dist/
dist-ssr/
*.local

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Claves privadas y certificados ----------
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
docker/gateway/certs/

# ---------- Terraform ----------
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ---------- Docker ----------
docker/n8n/data/

# ---------- IDE / Editor ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
Thumbs.db

# ---------- OS ----------
.DS_Store
Desktop.ini